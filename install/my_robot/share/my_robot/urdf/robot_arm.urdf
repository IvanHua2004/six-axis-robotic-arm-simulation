<?xml version="1.0"?>
<robot name="six_axis_robot_arm">

  <link name="world"/>

  <!-- ========== BASE YAW (continuous rotation around Z) ========== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="base_yaw" type="continuous">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== SHOULDER (pitch around Y) ========== -->
  <link name="upper_arm">
    <visual>
      <origin xyz="0.2 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.03" length="0.4"/></geometry>
      <material name="blue"><color rgba="0.15 0.15 0.75 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.4 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.035"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="shoulder_pitch" type="continuous">
    <parent link="base_link"/>
    <child link="upper_arm"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== ELBOW (pitch around Y) ========== -->
  <link name="forearm">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.025" length="0.3"/></geometry>
      <material name="green"><color rgba="0.15 0.75 0.15 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="elbow_pitch" type="continuous">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0.4 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== WRIST (pitch around Y) ========== -->
  <link name="claw_base">
    <visual>
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.07 0.03"/></geometry>
      <material name="steel"><color rgba="0.65 0.65 0.7 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.065 0 0" rpy="0 0 0"/>
      <geometry><box size="0.01 0.07 0.025"/></geometry>
      <material name="dark_steel"><color rgba="0.4 0.4 0.45 1"/></material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="wrist_pitch" type="continuous">
    <parent link="forearm"/>
    <child link="claw_base"/>
    <origin xyz="0.3 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5" velocity="1.0"/>
  </joint>

  <!-- ========== CLAW LEFT FINGER (prismatic, Y direction) ========== -->
  <link name="claw_left">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry><box size="0.1 0.015 0.02"/></geometry>
      <material name="steel"><color rgba="0.65 0.65 0.7 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.105 0 -0.015" rpy="0 0.5 0"/>
      <geometry><box size="0.04 0.015 0.018"/></geometry>
      <material name="steel"><color rgba="0.65 0.65 0.7 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.07 0 -0.012" rpy="0 0 0"/>
      <geometry><box size="0.06 0.013 0.005"/></geometry>
      <material name="grip"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="claw_left_joint" type="prismatic">
    <parent link="claw_base"/>
    <child link="claw_left"/>
    <origin xyz="0.07 0.025 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.04" effort="5" velocity="0.5"/>
  </joint>

  <!-- ========== CLAW RIGHT FINGER (prismatic, -Y direction) ========== -->
  <link name="claw_right">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry><box size="0.1 0.015 0.02"/></geometry>
      <material name="steel"><color rgba="0.65 0.65 0.7 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.105 0 -0.015" rpy="0 0.5 0"/>
      <geometry><box size="0.04 0.015 0.018"/></geometry>
      <material name="steel"><color rgba="0.65 0.65 0.7 1"/></material>
    </visual>
    <visual>
      <origin xyz="0.07 0 -0.012" rpy="0 0 0"/>
      <geometry><box size="0.06 0.013 0.005"/></geometry>
      <material name="grip"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="claw_right_joint" type="prismatic">
    <parent link="claw_base"/>
    <child link="claw_right"/>
    <origin xyz="0.07 -0.025 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.04" effort="5" velocity="0.5"/>
  </joint>

</robot>